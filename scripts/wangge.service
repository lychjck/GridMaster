[Unit]
Description=Wangge Backend Service
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/var/www/wangge/src/backend
Environment="BINANCE_BASE_URL=https://lychjck.qzz.io"
ExecStart=/var/www/wangge/src/backend/wangge-backend
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
